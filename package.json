{
  "name": "rag-kbs",
  "version": "0.0.1",
  "description": "RAG-KBS is a framework for building knowledge bases using RAG.",
  "author": "Amir Hossein Salighedar",
  "private": true,
  "type": "module",
  "license": "private",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "prisma generate && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch --preserveWatchOutput --no-shell",
    "start:debug": "nest start --debug --watch --preserveWatchOutput --no-shell",
    "start:prod": "node dist/main.js",
    "start:worker": "nest start --entryFile workers/ingestion.worker",
    "start:worker:dev": "nest start --watch --preserveWatchOutput --no-shell --entryFile workers/ingestion.worker",
    "worker:dev": "nest start --watch --preserveWatchOutput --no-shell --entryFile workers/ingestion.worker",
    "worker:prod": "node dist/workers/ingestion.worker.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"prisma/**/*.ts\" \"*.json\" \"*.yml\" \"pnpm-workspace.yaml\" \"*.md\"",
    "typecheck": "tsc --noEmit",
    "check-types": "pnpm typecheck",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:debug": "node --inspect-brk --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config ./test/jest-e2e.json --runInBand --detectOpenHandles",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:prod": "pnpm db:migrate:deploy",
    "db:migrate:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "db:push": "prisma db push",
    "docker:dev": "docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build -d ",
    "docker:dev:migrate": "docker compose -f docker-compose.yml -f docker-compose.dev.yml --profile tools run --rm migrate-dev",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml --profile self-hosted up --build -d",
    "docker:prod:migrate": "docker compose -f docker-compose.yml -f docker-compose.prod.yml run --rm migrate"
  },
  "prisma": {
    "seed": "node --loader ts-node/esm prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1079.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "nestjs-zod": "^5.4.0",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma-dbml-generator": "^0.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@jest/globals": "30.4.1",
    "@jest/types": "^30.4.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^.+generated/prisma/client(\\.js)?$": "<rootDir>/../test/mocks/prisma-client.mock.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "rootDir": "src",
    "setupFiles": [
      "<rootDir>/../test/setup-env.ts"
    ],
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
