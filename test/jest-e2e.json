{
  "moduleFileExtensions": ["js", "json", "ts"],
  "extensionsToTreatAsEsm": [".ts"],
  "rootDir": ".",
  "setupFiles": ["<rootDir>/setup-env.ts"],
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "moduleNameMapper": {
    "^.+generated/prisma/client(\\.js)?$": "<rootDir>/mocks/prisma-client.mock.ts",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      {
        "useESM": true
      }
    ]
  }
}
