NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://rag_kbs:change-me@postgres:5432/rag_kbs
POSTGRES_USER=rag_kbs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rag_kbs
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=change-me-if-required
QDRANT_COLLECTION=rag_kbs_production

STORAGE_DRIVER=s3
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=rag-kbs-production
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=false

MINIO_ROOT_USER=rag-kbs-minio
MINIO_ROOT_PASSWORD=change-me

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=change-me

BULLMQ_QUEUE_PREFIX=rag-kbs
INGESTION_QUEUE_NAME=ingestion

LOG_LEVEL=info
WAIT_FOR_HOSTS=postgres:5432,redis:6379,qdrant:6333
MIGRATE_WAIT_FOR_HOSTS=postgres:5432
API_WAIT_FOR_HOSTS=postgres:5432,redis:6379,qdrant:6333
WORKER_WAIT_FOR_HOSTS=postgres:5432,redis:6379,qdrant:6333
WAIT_TIMEOUT_SECONDS=120
WORKER_READY_FILE=/tmp/rag-kbs-worker.ready
