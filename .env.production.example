NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://rag_kbs:change-me@postgres:5432/rag_kbs
DEFAULT_TENANT_ID=default
POSTGRES_USER=rag_kbs
POSTGRES_PASSWORD=change-me
POSTGRES_DB=rag_kbs
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=change-me-if-required
QDRANT_COLLECTION=rag_kbs_production
QDRANT_COLLECTION_NAME=rag_kbs_production
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE_METRIC=Cosine
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_TIMEOUT_MS=30000

STORAGE_DRIVER=s3
LOCAL_STORAGE_PATH=
S3_ENDPOINT=https://s3.example.com
S3_REGION=us-east-1
S3_BUCKET=rag-kbs-production
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_FORCE_PATH_STYLE=false

MINIO_ROOT_USER=rag-kbs-minio
MINIO_ROOT_PASSWORD=change-me

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_DISTANCE_METRIC=Cosine
EMBEDDING_BATCH_SIZE=64
EMBEDDING_TIMEOUT_MS=30000
EMBEDDING_MAX_RETRIES=3
EMBEDDING_API_KEY=change-me
OPENAI_API_KEY=change-me
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_CHAT_MODEL=deepseek/deepseek-v4-flash

CHUNKING_DEFAULT_SIZE=800
CHUNKING_DEFAULT_OVERLAP=120
CHUNKING_TEXT_PREVIEW_LENGTH=1000
CHUNKING_MAX_CHUNKS_PER_DOCUMENT=10000

RETRIEVAL_DEFAULT_TOP_K=8
RETRIEVAL_MAX_TOP_K=30
RETRIEVAL_DEFAULT_SCORE_THRESHOLD=0
RETRIEVAL_TIMEOUT_MS=30000
RETRIEVAL_STORE_QUERY_TEXT=true
RETRIEVAL_STORE_RESULTS=true
RETRIEVAL_INCLUDE_TEXT_DEFAULT=true
RETRIEVAL_INCLUDE_METADATA_DEFAULT=true

MAX_UPLOAD_SIZE_MB=50
ALLOWED_UPLOAD_MIME_TYPES=application/pdf,text/plain,text/markdown,application/json,text/csv,text/html,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet
INGESTION_QUEUE_NAME=ingestion
INGESTION_CONCURRENCY=3
INGESTION_MAX_ATTEMPTS=3
INGESTION_BACKOFF_DELAY_MS=5000
INGESTION_REMOVE_ON_COMPLETE_COUNT=1000
INGESTION_REMOVE_ON_FAIL_COUNT=5000
INGESTION_JOB_TIMEOUT_MS=120000
INGESTION_MAX_TEXT_CONTENT_BYTES=1048576
INGESTION_TEXT_PREVIEW_LENGTH=1000

BULLMQ_QUEUE_PREFIX=rag-kbs
LOG_LEVEL=info
LOG_FORMAT=json
LOG_DIR=logs
LOG_ROTATION_ENABLED=true
LOG_RETENTION_DAYS=14
REQUEST_LOGGING_ENABLED=true
REQUEST_BODY_LOGGING_ENABLED=false
WAIT_FOR_HOSTS=postgres:5432,redis:6379,qdrant:6333
MIGRATE_WAIT_FOR_HOSTS=postgres:5432
API_WAIT_FOR_HOSTS=postgres:5432,redis:6379,qdrant:6333
WORKER_WAIT_FOR_HOSTS=postgres:5432,redis:6379,qdrant:6333
WAIT_TIMEOUT_SECONDS=120
WORKER_READY_FILE=/tmp/rag-kbs-worker.ready

SERVICE_NAME=rag-kbs-api
APP_VERSION=
POSTGRES_HEALTH_TIMEOUT_MS=2000
REDIS_HEALTH_TIMEOUT_MS=2000
QDRANT_HEALTH_TIMEOUT_MS=3000
STORAGE_HEALTH_TIMEOUT_MS=3000
QUEUE_HEALTH_TIMEOUT_MS=2000
